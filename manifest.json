{
  "manifest_version": 3,
  "name": "AI Side Panel Pro",
  "version": "2.0.0",
  "description": "Professional AI workflow solution with premium features, team collaboration, and enterprise security. Supercharge your productivity with advanced AI integration.",
  
  "permissions": [
    "sidePanel",
    "activeTab",
    "contextMenus",
    "storage",
    "tabs",
    "scripting",
    "webNavigation",
    "identity",
    "unlimitedStorage",
    "management"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Side Panel Pro - Premium AI Workspace",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png", 
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "Command+Q"
      },
      "description": "Toggle AI Side Panel"
    },
    "quick-ai-chat": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Command+A"
      },
      "description": "Quick AI Chat"
    }
  },
  
  "options_page": "options.html",
  
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "styles/*",
        "templates/*",
        "ai-services.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  
  "externally_connectable": {
    "matches": [
      "https://ai-side-panel-pro.com/*",
      "https://*.ai-side-panel-pro.com/*"
    ]
  }
}